#!/usr/bin/env bash
set -euo pipefail

# wcir-up: installer and updater for whatcanirun CLI
# Usage:
#   curl -fsSL whatcani.run/install | bash    (first install)
#   wcir-up                                    (update)

INSTALL_DIR="${WHATCANIRUN_HOME:-$HOME/.whatcanirun}/bin"
PACKAGE="@whatcanirun/cli"

# -----------------------------------------------------------------------------
# Helpers
# -----------------------------------------------------------------------------

say() { printf "\033[1m%s\033[0m\n" "$*"; }
err() { printf "\033[31merror:\033[0m %s\n" "$*" >&2; exit 1; }

# -----------------------------------------------------------------------------
# Main
# -----------------------------------------------------------------------------

main() {
  local npm_cmd

  # Find a package manager
  if command -v bun &>/dev/null; then
    npm_cmd="bun"
  elif command -v npm &>/dev/null; then
    npm_cmd="npm"
  else
    err "bun or npm is required. Install bun: https://bun.sh"
  fi

  say "Using ${npm_cmd} to install ${PACKAGE}..."

  mkdir -p "$INSTALL_DIR"

  # Install the package globally into our directory
  if [ "$npm_cmd" = "bun" ]; then
    BUN_INSTALL="${WHATCANIRUN_HOME:-$HOME/.whatcanirun}" bun install -g "$PACKAGE"
  else
    npm install -g --prefix "${WHATCANIRUN_HOME:-$HOME/.whatcanirun}" "$PACKAGE"
  fi

  # Install wcir-up itself if not already present
  if [ ! -f "${INSTALL_DIR}/wcir-up" ]; then
    cp "$0" "${INSTALL_DIR}/wcir-up" 2>/dev/null || true
    chmod +x "${INSTALL_DIR}/wcir-up" 2>/dev/null || true
  fi

  ensure_path

  local version
  version=$("${INSTALL_DIR}/whatcanirun" version 2>/dev/null || echo "unknown")

  say ""
  say "wcir installed to ${INSTALL_DIR}"
  say "Run 'wcir --help' to get started"
  say "Run 'wcir-up' to update"
}

ensure_path() {
  local line="export PATH=\"${INSTALL_DIR}:\$PATH\""
  local updated=false

  # Skip if already on PATH
  case ":${PATH}:" in
    *":${INSTALL_DIR}:"*) return ;;
  esac

  for rc in "$HOME/.zshrc" "$HOME/.bashrc" "$HOME/.bash_profile"; do
    if [ -f "$rc" ]; then
      if ! grep -qF "$INSTALL_DIR" "$rc"; then
        echo "" >> "$rc"
        echo "# whatcanirun" >> "$rc"
        echo "$line" >> "$rc"
        updated=true
      fi
    fi
  done

  if $updated; then
    say "Added ${INSTALL_DIR} to PATH (restart your shell or run: source ~/.zshrc)"
  fi
}

main "$@"
